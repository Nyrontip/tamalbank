{
  "info": {
    "name": "TamalBank API",
    "description": "API para gestionar gastos y saldo bancario",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8084/api",
      "type": "string"
    },
    {
      "key": "personId",
      "value": "240420241036",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"person_id\": \"{{personId}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Account",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/account/{{personId}}"
          }
        },
        {
          "name": "Deduct Balance",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/account/{{personId}}/deduct",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 10, \"reason\": \"Prueba de descuento\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List All Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/1"
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [{"key": "type", "value": "alimentacion"}]
            }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Get Expenses by User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/expenses/{{personId}}?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["expenses", "{{personId}}"],
              "query": [
                {"key": "limit", "value": "20"},
                {"key": "offset", "value": "0"},
                {"key": "type", "value": "alimentacion", "disabled": true}
              ]
            }
          }
        },
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses/{{personId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"product_id\": 1, \"type\": \"alimentacion\", \"description\": \"Orejas de Pollo\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Tamalbits",
      "item": [
        {
          "name": "Get Tamalbits by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tamalbits/{{personId}}"
          }
        }
      ]
    },
    {
      "name": "Status",
      "item": [
        {
          "name": "Get API Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/status"
          }
        }
      ]
    }
  ]
}